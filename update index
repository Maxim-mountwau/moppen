<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>De Ultieme Moppentrommel</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f4f7f6;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }

        .card {
            background: white;
            padding: 35px;
            border-radius: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 450px;
            width: 100%;
            margin-top: 20px;
        }

        h2 { color: #2c3e50; font-size: 22px; line-height: 1.5; min-height: 60px; }

        #answer {
            display: none;
            margin: 25px 0;
            font-weight: bold;
            font-size: 24px;
            color: #27ae60;
            padding: 15px;
            background: #f0fff4;
            border-radius: 10px;
            animation: fadeIn 0.4s;
        }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .btn-container { display: flex; flex-direction: column; gap: 12px; margin-top: 20px; }

        button {
            padding: 16px;
            font-size: 16px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.2s;
        }

        .primary-btn { background: #000; color: #fff; }
        .star-btn { background: #ffcc00; color: #000; }
        .refresh-btn { background: #eee; color: #555; }

        button:active { transform: scale(0.95); }

        .saved-list {
            margin-top: 40px;
            width: 100%;
            max-width: 450px;
        }

        .fav-card {
            background: #fff;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 10px;
            border-left: 6px solid #ffcc00;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            font-size: 14px;
        }

        .clear-btn {
            background: none;
            color: #e74c3c;
            font-size: 12px;
            text-decoration: underline;
            padding: 5px;
            margin-top: 10px;
        }
    </style>
</head>
<body>

    <div class="card">
        <h2 id="joke-q">Mop wordt geladen...</h2>
        <div id="answer"></div>

        <div class="btn-container">
            <button class="primary-btn" onclick="showAnswer()">💡 Toon Antwoord</button>
            <button class="star-btn" onclick="saveMop()">⭐ Bewaar Mop</button>
            <button class="refresh-btn" onclick="getNewLocalJoke()">Volgende Mop ➡️</button>
        </div>
    </div>

    <div class="saved-list">
        <h3 style="text-align: center; color: #7f8c8d;">⭐ Jouw Favorieten</h3>
        <div id="fav-container"></div>
        <center><button class="clear-btn" onclick="clearFavs()">Favorieten wissen</button></center>
    </div>

<script>
    // Grote lijst met Nederlandse moppen
    const moppenDatabase = [
        { q: "Het is groen en het skiet van de berg?", a: "Een ski-wi!" },
        { q: "Waarom neemt een dom blondje een ladder mee naar de winkel?", a: "Omdat de prijzen zo hoog zijn!" },
        { q: "Wat is geel en roept: 'Ik ben een appel'?", a: "Een banaan met een identiteitscrisis!" },
        { q: "Hoe noem je een konijn met een zonnebril?", a: "Een fel-be-haard!" },
        { q: "Waarom kan een skelet niet goed liegen?", a: "Je kijkt er zo dwars doorheen!" },
        { q: "Het is blauw en weegt niet veel?", a: "Lichtblauw!" },
        { q: "Wat is het toppunt van geduld?", a: "Een vis op de muur tekenen en wachten tot hij wegzwemt." },
        { q: "Waarom loopt een dom blondje in de winter met een schaar over straat?", a: "Om de kou in te snijden!" },
        { q: "Wat is groen en roept: 'Ik ben een aardbei'?", a: "Een onrijpe aardbei!" },
        { q: "Hoe heet een vlieg die op de wc zit?", a: "Een drol-vlieg!" },
        { q: "Waarom kan een vis niet praten?", a: "Heb jij weleens geprobeerd onder water te praten?" },
        { q: "Wat is oranje en roept: 'Ik ben een wortel'?", a: "Een wortel!" },
        { q: "Wat is het toppunt van snelheid?", a: "Een slak die uit de bocht vliegt!" },
        { q: "Waarom dragen muizen geen schoenen?", a: "Omdat ze op blote pootjes lopen!" },
        { q: "Wat is rood en zit op een hek?", a: "Verf!" },
        { q: "Wat is zwart, wit en rood?", a: "Een zebra met zonnebrand!" },
        { q: "Waarom heeft een koe een bel om haar nek?", a: "Omdat haar horens het niet doen!" },
        { q: "Hoe noem je een boomerang die niet terugkomt?", a: "Een stok!" },
        { q: "Wat is het favoriete drinken van een spook?", a: "Boe-lende limonade!" },
        { q: "Waarom gaat een dom blondje altijd op de grond zitten in de bioscoop?", a: "Omdat ze heeft gehoord dat de film gaat vallen!" },
        { q: "Wat is geel en weegt 1000 kilo?", a: "Een bananenvla-vrachtwagen!" },
        { q: "Hoe noem je een vlieg zonder vleugels?", a: "Een loop!" },
        { q: "Wat is de overeenkomst tussen een ober en een wolk?", a: "Als ze weggaan wordt het mooi weer!" },
        { q: "Waarom kijkt een dom blondje altijd door het sleutelgat van de koelkast?", a: "Ze wil zien of het lichtje wel echt uitgaat!" },
        { q: "Wat is grijs en heel zwaar?", a: "Een olifant!" },
        { q: "Wat is klein, rond en lacht?", a: "Een giebel-erwt!" },
        { q: "Waarom neemt een skelet nooit een bad?", a: "Omdat hij dan een rammelaar wordt!" },
        { q: "Hoe noem je een hond zonder poten?", a: "Die hoef je niet te roepen, die komt toch niet!" },
        { q: "Wat is groen en erg onbeleefd?", a: "Een brutaal-tje!" },
        { q: "Hoe heet een konijn dat naar de sportschool gaat?", a: "Een sports-haas!" },
        { q: "Wat is wit en ontploft?", a: "Een boem-kool!" },
        { q: "Waarom heeft een giraf zo'n lange nek?", a: "Omdat zijn kop zo ver van zijn lichaam zit!" },
        { q: "Wat is bruin en plakt?", a: "Een plak-stok!" },
        { q: "Waarom ligt een baby-visje altijd in de wieg?", a: "Omdat het nog niet kan zwemmen!" },
        { q: "Wat is zwart en als het uit de boom valt is je kachel kapot?", a: "Je kachel!" },
        { q: "Hoe noem je een dief die in de bibliotheek steelt?", a: "Een boek-houder!" },
        { q: "Waarom dragen olifanten groene sportschoenen?", a: "Dan vallen ze niet op in het gras!" },
        { q: "Wat is het toppunt van nieuwsgierigheid?", a: "Door het sleutelgat van een glazen deur kijken!" },
        { q: "Hoe noem je een schaap zonder pootjes?", a: "Een wolkje!" }
    ];

    let currentMop = { q: "", a: "" };

    function getNewLocalJoke() {
        const qElement = document.getElementById("joke-q");
        const aElement = document.getElementById("answer");

        // UI Reset
        aElement.style.display = "none";
        
        // Kies een willekeurige mop uit de lijst
        const random = Math.floor(Math.random() * moppenDatabase.length);
        currentMop = moppenDatabase[random];

        qElement.innerText = currentMop.q;
        aElement.innerText = currentMop.a;
    }

    function showAnswer() {
        document.getElementById("answer").style.display = "block";
    }

    function saveMop() {
        let favorites = JSON.parse(localStorage.getItem("moppenFavorieten")) || [];
        
        // Voorkom dubbele
        if (!favorites.some(m => m.q === currentMop.q)) {
            favorites.push({...currentMop});
            localStorage.setItem("moppenFavorieten", JSON.stringify(favorites));
            renderFavorites();
        }
    }

    function renderFavorites() {
        const container = document.getElementById("fav-container");
        const favorites = JSON.parse(localStorage.getItem("moppenFavorieten")) || [];
        
        if (favorites.length === 0) {
            container.innerHTML = "<p style='text-align:center; color:#999;'>Nog geen favorieten.</p>";
            return;
        }

        container.innerHTML = favorites.map(m => `
            <div class="fav-card">
                <strong>V: ${m.q}</strong><br>
                <span style="color: #27ae60;">A: ${m.a}</span>
            </div>
        `).reverse().join("");
    }

    function clearFavs() {
        if(confirm("Alle favorieten wissen?")) {
            localStorage.removeItem("moppenFavorieten");
            renderFavorites();
        }
    }

    // Automatisch een mop tonen bij openen
    window.onload = () => {
        getNewLocalJoke();
        renderFavorites();
    };
</script>

</body>
</html>
